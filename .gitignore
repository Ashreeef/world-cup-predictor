# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.ipynb_checkpoints/

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/

# ── Trained model artifacts (regenerated by the pipeline) ──────────────────────
artifacts/*.pkl
artifacts/*.joblib
artifacts/*.json

# ── Data: keep raw sources out of git if large; keep folder structure ──────────
# We commit small reference data but ignore large / regenerated files.
data/raw/*
data/processed/*
data/predictions/*
data/live/match_updates/*
data/live/applied_matches.csv
!**/.gitkeep

# ── Reports (regenerated) ──────────────────────────────────────────────────────
reports/*
!reports/.gitkeep

# ── OS / IDE ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

# ── Testing / coverage ─────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
